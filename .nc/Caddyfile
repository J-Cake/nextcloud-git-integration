{
# caddy-git-jwt: unwrap Git's OAuth Basic before jwtauth sees it
    order jwtauth before basicauth
    log {
        output stderr
        format console
        level INFO
    }
}

localhost {
    root * /var/www/html

# Nextcloud well-known redirects
    redir /.well-known/carddav /remote.php/dav 301
    redir /.well-known/caldav  /remote.php/dav 301

# Block internal paths
    @forbidden path /.htaccess /data/* /config/* /README /3rdparty/* /lib/* /templates/* /occ /console.php
    respond @forbidden 403

# Both processes share the container — FPM listens on localhost
    php_fastcgi 127.0.0.1:9000 {
        env front_controller_active true
    }

    file_server

    encode gzip
}